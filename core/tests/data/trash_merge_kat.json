      "expected": [
        {"block_uuid_hex": "0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a0a", "tombstoned_at_ms": 100, "tombstoned_by_hex": "01010101010101010101010101010101", "fingerprint_hex": null, "purged_at_ms": null, "unknown_hex": {"ka": "0a", "kb": "0b"}}
