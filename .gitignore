cython_debug/

# PyCharm
#   JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#   be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#   and can be added to the global gitignore or merged into this file.  For a more nuclear
#   option (not recommended) you can uncomment the following to ignore the entire idea folder.
# .idea/

# Abstra
#   Abstra is an AI-powered process automation framework.
#   Ignore directories containing user credentials, local state, and settings.
#   Learn more at https://abstra.io/docs
.abstra/

# Visual Studio Code
#   Visual Studio Code specific template is maintained in a separate VisualStudioCode.gitignore 
#   that can be found at https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
#   and can be added to the global gitignore or merged into this file. However, if you prefer, 
#   you could uncomment the following to ignore the entire vscode folder
# .vscode/
# Temporary file for partial code execution
tempCodeRunnerFile.py

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Rust
/target/
**/*.rs.bk

# proptest auto-saves a regression file next to a failing test; we
# don't pin past failures into version control.
**/*.proptest-regressions

# uniffi-generated foreign-language bindings + compiled smoke runners.
# Bindings are regenerated by `tests/swift/run.sh` and `tests/kotlin/run.sh`
# on every invocation, so committing them would just create drift. The
# smoke-runner binaries (Swift native + Kotlin fat-jar) are build
# products of swiftc / kotlinc, not source. The Kotlin lib/ directory
# holds a fetched-and-verified jna.jar (integrity-pinned in run.sh).
/ffi/secretary-ffi-uniffi/bindings/
/ffi/secretary-ffi-uniffi/tests/swift/secretary_smoke
/ffi/secretary-ffi-uniffi/tests/swift/secretary_smoke.dSYM/
/ffi/secretary-ffi-uniffi/tests/swift/secretary_conformance
/ffi/secretary-ffi-uniffi/tests/swift/secretary_conformance.dSYM/
/ffi/secretary-ffi-uniffi/tests/kotlin/lib/
/ffi/secretary-ffi-uniffi/tests/kotlin/secretary_smoke.jar
/ffi/secretary-ffi-uniffi/tests/kotlin/secretary_conformance.jar

# Claude Code per-user state (settings, generated skills). Project-level
# Claude config (.claude/CLAUDE.md, .claude/agents/, etc.) may be
# committed selectively if introduced later.
# .claude/settings.local.json
# .claude/skills/

# Git worktrees — isolated per-feature branches live under .worktrees/
# (skill: superpowers:using-git-worktrees). Each worktree is its own
# branch checkout; the directory should not appear in main's tree.
.worktrees/

# Playwright MCP cache — local browser automation state, not source.
.playwright-mcp/

# Monitor smoke-test screenshots — eyeballed during NiceGUI dashboard
# verification, not artefacts worth committing. Scoped to repo root so
# committed asset PNGs (e.g. assets/secretary_logo.png) are unaffected.
/monitor-*.png

# Superpowers visual-companion (brainstorming UI) session state. Local
# scratch — mockups, server PIDs, and event logs that exist only for
# the duration of a brainstorming session.
.superpowers/

# Tauri 2 desktop client (D.1.x). Frontend deps, Vite output, and the
# Cargo target dir for `secretary-desktop` (Tauri's build dir lives at
# desktop/src-tauri/target, distinct from the workspace target at
# /target). `gen/` is uniffi/tauri-bridge generated content per build.
desktop/node_modules/
desktop/target/
desktop/dist/
desktop/src-tauri/target/
desktop/src-tauri/gen/

.claude/settings.local.json
